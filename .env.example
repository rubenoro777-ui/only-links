# ----------------------------------------------------------------------------
# OnlyLinks environment variables
# Copy this file to `.env.local` and fill in the values from your Supabase
# project (Project Settings -> API). NEVER commit `.env.local`.
# ----------------------------------------------------------------------------

# Public Supabase project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key (safe to expose to the browser; RLS protects your data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# The public base URL of the app. Used to build OAuth redirect URLs.
# Local dev: http://localhost:3000   Production: https://onlylinks.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# Server-only. NEVER prefix with NEXT_PUBLIC and NEVER expose to the client.
# REQUIRED for Stripe billing: the webhook uses this RLS-bypassing key to
# activate Pro subscriptions and record link unlocks. Also used by scripts/seed.
# Must be set in Vercel (Project Settings -> Environment Variables) for billing
# to work in production. Without it the webhook returns 503 and Stripe retries.
# ----------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=

# Used only by `pnpm gen:types` to regenerate database.types.ts
SUPABASE_PROJECT_ID=

# Supabase personal access token for auto-applying migrations on deploy
# (used by scripts/migrate.mjs via `pnpm migrate`).
# Create one at https://supabase.com/dashboard/account/tokens (Generate new
# token) and paste it here. Starts with sbp_. The project ref is read from
# NEXT_PUBLIC_SUPABASE_URL. Stays local (this file is gitignored); NOT needed on Vercel.
SUPABASE_ACCESS_TOKEN=

# ----------------------------------------------------------------------------
# Stripe (server-only except where noted). Get keys from
# https://dashboard.stripe.com/test/apikeys
# ----------------------------------------------------------------------------

# Secret API key — sk_test_... (dev) or sk_live_... (production). NEVER public.
STRIPE_SECRET_KEY=

# Webhook signing secret — whsec_... from Stripe Dashboard webhook endpoint,
# or from `stripe listen --forward-to localhost:3000/api/stripe/webhook` locally.
STRIPE_WEBHOOK_SECRET=

# Pro subscription Price IDs — price_... from Stripe Dashboard → Products.
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=
